// Обработчик GET /configuration
// Возвращает информацию о конфигурации и платформе.
//
// Ответ: JSON {"name": "...", "version": "...", "vendor": "...", "platform_version": "...", "mode": "file|server"}

Функция КонфигурацияGET(Запрос)
    Результат = Новый Структура;
    Результат.Вставить("name",             Метаданные.Имя);
    Результат.Вставить("version",          Метаданные.Версия);
    Результат.Вставить("vendor",           Метаданные.Поставщик);
    СИ = Новый СистемнаяИнформация;
    Результат.Вставить("platform_version", СИ.ВерсияПриложения);

    РежимИБ = "";
    Попытка
        СтрокаСоединения = СтрокаСоединенияИнформационнойБазы();
        Если СтрНайти(ВРег(СтрокаСоединения), "FILE=") > 0 Тогда
            РежимИБ = "file";
        ИначеЕсли СтрНайти(ВРег(СтрокаСоединения), "SRVR=") > 0 Тогда
            РежимИБ = "server";
        КонецЕсли;
    Исключение
    КонецПопытки;
    Результат.Вставить("mode", РежимИБ);

    Возврат ОтветJSON(Результат);
КонецФункции

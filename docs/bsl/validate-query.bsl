// Обработчик POST /validate-query
// Проверяет синтаксис запроса на языке запросов 1С без выполнения.
//
// Тело запроса: JSON {"query": "ВЫБРАТЬ ..."}
// Ответ: JSON {"valid": true/false, "errors": ["...", ...]}
//
// Использует СхемаЗапроса для разбора текста запроса.
// Если запрос корректен — valid=true, errors пустой.
// Если есть синтаксические ошибки — valid=false, errors содержит описания ошибок.
//
// ВАЖНО: СхемаЗапроса доступна начиная с платформы 8.3.5.
//
// ПРИМЕЧАНИЕ: Вспомогательные функции ОтветJSON, ОтветОшибка, РазобратьJSON, СформироватьJSON
// и НайтиМетаданныеПоТипуИИмени определены в основном модуле HTTP-сервиса (Module.bsl).

Функция ПроверкаЗапросаPOST(Запрос)
    Параметры = РазобратьJSON(Запрос.ПолучитьТелоКакСтроку());

    ТекстЗапроса = Параметры.query;
    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Возврат ОтветОшибка(400, "query is required");
    КонецЕсли;

    Ошибки = Новый Массив;

    Попытка
        СхемаЗапроса = Новый СхемаЗапроса;
        СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);
        СхемаЗапроса.ПолучитьТекстЗапроса();

        Результат = Новый Структура;
        Результат.Вставить("valid", Истина);
        Результат.Вставить("errors", Ошибки);
    Исключение
        Результат = Новый Структура;
        Результат.Вставить("valid", Ложь);
        Ошибки.Добавить(ОписаниеОшибки());
        Результат.Вставить("errors", Ошибки);
    КонецПопытки;

    Возврат ОтветJSON(Результат);
КонецФункции

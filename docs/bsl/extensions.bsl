// Обработчик GET /extensions
// Возвращает бинарные данные (.cfe) всех расширений конфигурации в base64.
// MCP-сервер парсит .cfe локально для поиска и чтения кода расширений.
//
// Ответ: JSON [{"name": "МоёРасширение", "data": "<base64 .cfe>"}]

Функция РасширенияGET(Запрос)
    Результат = Новый Массив;

    Попытка
        МассивРасширений = РасширенияКонфигурации.Получить();
    Исключение
        Возврат ОтветJSON(Результат);
    КонецПопытки;

    Для Каждого Расширение Из МассивРасширений Цикл
        Попытка
            Данные = Расширение.ПолучитьДанные();
            ОписаниеРасш = Новый Структура;
            ОписаниеРасш.Вставить("name", Расширение.Имя);
            ОписаниеРасш.Вставить("data", Base64Строка(Данные));
            Результат.Добавить(ОписаниеРасш);
        Исключение
        КонецПопытки;
    КонецЦикла;

    Возврат ОтветJSON(Результат);
КонецФункции
